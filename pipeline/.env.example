# ═══════════════════════════════════════════════════════════
# HACKING CREATIVITY — PIPELINE ENGINE ENV SCAFFOLD
# Copy to .env and fill in values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════

# ── SUPABASE (already configured in OS) ──────────────────
SUPABASE_URL=https://yossieeqpgmvfuiiwcbl.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here   # for server-side job writes

# ── AI / SCRIPT GENERATION ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                       # Claude - script generation
OPENAI_API_KEY=sk-...                              # GPT fallback / embeddings

# ── VOICE / AUDIO ────────────────────────────────────────
ELEVENLABS_API_KEY=...                             # TTS voiceover synthesis
ELEVENLABS_VOICE_ID=...                            # default voice ID

# ── MEDIA INTELLIGENCE ───────────────────────────────────
VIDEODB_API_KEY=...                                # screen recording analysis, URL scrape

# ── RENDER OUTPUT ────────────────────────────────────────
OUTPUT_DIR=./output                                # local render output path
REMOTION_CONCURRENCY=2                             # parallel render threads (increase with GPU)
REMOTION_LOG=verbose                               # verbose | info | silent

# ── DAVINCI RESOLVE (local, no key needed) ───────────────
DAVINCI_PROJECT_NAME=HackingCreativity            # project name inside DaVinci
DAVINCI_BIN_NAME=Pipeline_Output                  # bin where renders land
DAVINCI_COLORSPACE=DaVinci Wide Gamut             # default colorspace
DAVINCI_RENDER_PRESET=H.264 Master               # render preset name

# ── PLATFORM TOKENS (for direct upload, add later) ───────
# YOUTUBE_CLIENT_ID=...
# YOUTUBE_CLIENT_SECRET=...
# INSTAGRAM_ACCESS_TOKEN=...
